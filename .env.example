# ============================================================
# Agentic AI リスク評価ツール — 環境変数サンプル
# ============================================================
# このファイルをコピーして .env を作成し、値を設定してください。
# cp .env.example .env
# ============================================================

# ------------------------------------------------------------
# OpenAI API（必須）
# GPT-4o を使用した情報抽出・リスク評価に必要です。
# https://platform.openai.com/api-keys
# ------------------------------------------------------------
OPENAI_API_KEY=

# ------------------------------------------------------------
# データベース（API サーバーを使用する場合に必要）
# PostgreSQL の接続文字列を設定してください。
# 例: postgresql://user:password@localhost:5432/dbname
# ------------------------------------------------------------
DATABASE_URL=

# ------------------------------------------------------------
# サーバー設定（任意）
# デフォルト値が使用されるため、変更が必要な場合のみ設定。
# ------------------------------------------------------------

# Gradio UI のポート番号（デフォルト: 8000）
PORT=
